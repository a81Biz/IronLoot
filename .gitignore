# =====================================================
# IronLoot - Git Ignore Configuration
# =====================================================
# This .gitignore ensures only essential files are tracked
# - Source code, configuration, migrations
# - Excludes secrets, build artifacts, dependencies, and generated files

# =====================================================
# SECTION 1: ENVIRONMENT & SECRETS
# =====================================================
# Never commit environment variables or credentials
.env
.env.local
.env.*.local
api/.env
api/.env.local
api/.env.*.local
web/.env
web/.env.local
web/.env.*.local
admin/.env
admin/.env.local
admin/.env.*.local

# Sensitive files
*.key
*.pem
*.p8
*.pfx
.ssh/
.credentials/
credentials.json
secrets.json

# =====================================================
# SECTION 2: NODE.JS & DEPENDENCIES
# =====================================================
# Package managers - regenerated by npm/yarn/pnpm
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnpm-store/

# Dependency cache
npm-debug.log
npm-debug.log*
npm-error.log
npm-error.log*
yarn-debug.log
yarn-error.log

# =====================================================
# SECTION 3: BUILD & COMPILATION ARTIFACTS
# =====================================================
# These are regenerated by npm run build / tsc
dist/
api/dist/
web/dist/
admin/dist/
build/
.tsbuildinfo
tsconfig.tsbuildinfo
tsconfig.build.tsbuildinfo
*.tsbuildinfo
*.js
*.d.ts
*.js.map
*.d.ts.map
!*.config.js      # Keep config files
!jest.config.js
!.eslintrc.js
!.prettierrc.js

# =====================================================
# SECTION 4: IDE & EDITOR
# =====================================================
# Local IDE settings (optional - might keep .vscode/)
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-workspace
*.sublime-project

# Local Claude Code configuration
.claude/settings.json

# =====================================================
# SECTION 5: TESTING & COVERAGE
# =====================================================
coverage/
.nyc_output/
test-results/
*.lcov
.coverage/
htmlcov/
jest-coverage/

# Test artifacts
*.spec.js
*.test.js
.jest-cache/

# =====================================================
# SECTION 6: DOCUMENTATION & INTERNAL
# =====================================================
# Internal documentation for developers (not for distribution)
implementation/
docs/
CLAUDE.md
GRAPH_REPORT.md
graphify-out/
graphify-cache/
graphify-temp/

# Local working files
todo.md
*.draft.md
notes/
scratch/

# =====================================================
# SECTION 7: OS & RUNTIME
# =====================================================
# Operating system files
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
.metadata
*.sublime-project
*.sublime-workspace

# IDE lock files
.vscode/.settings.json.lock
.idea/.lock

# =====================================================
# SECTION 8: LOGS & TEMPORARY FILES
# =====================================================
# Application logs
logs/
*.log
*.log.*
lerna-debug.log*
lerna.log

# Temporary files
tmp/
temp/
*.tmp
*.temp
.tmp/

# Docker build cache
.docker-cache/

# Process files
*.pid
*.seed
*.pid.lock

# =====================================================
# SECTION 9: DATABASE & DATA
# =====================================================
# Database files
*.db
*.sqlite
*.sqlite3
database/data/
db/data/
postgres_data/

# Uploads and user-generated content (app-specific)
uploads/
api/uploads/
web/uploads/
admin/uploads/

# Backups
*.backup
*.bak
backup/
backups/

# =====================================================
# SECTION 10: ENVIRONMENT-SPECIFIC
# =====================================================
# Development-only directories
.cache/
.env.development.local
.env.test.local
.env.production.local
.env.qa.local

# Platform-specific
platform-specific/
.AppleDouble
Zone.identifier

# =====================================================
# SECTION 11: VSCODE EXTENSIONS (optional keep this section for settings)
# =====================================================
# Uncomment if you want to share useful extensions list (optional)
# .vscode/extensions.json can be kept

# =====================================================
# EXCEPTIONS - FORCED INCLUSION
# =====================================================
# Use !pattern to force-include files that match a blanket exclude above

# Keep configuration examples and templates
!.env.example
!api/.env.example
!web/.env.example
!admin/.env.example

# Keep Docker and deployment config
!nginx/
!docker-compose.yml
!.github/

# Keep essential build config
!tsconfig.json
!tsconfig.build.json
!jest.config.js
!.eslintrc.js
!.prettierrc

# Keep git-related files
!.gitattributes
!.github/

# Keep husky hooks
!.husky/

# Keep useful IDE defaults
!.vscode/extensions.json
!.vscode/settings.json

QA/
.graphify_*

# =====================================================
# END OF GITIGNORE
# =====================================================
