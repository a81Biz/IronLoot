# ===========================================
# Iron Loot - Environment Configuration
# ===========================================
# Copy this file to .env and adjust values as needed
# NEVER commit .env to version control

# -------------------------------------------
# Environment
# -------------------------------------------
NODE_ENV=development
# Options: development, qa, production

# -------------------------------------------
# API Configuration
# -------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=ironloot_db
DB_USER=ironloot
DB_PASSWORD=ironloot_dev

# Full connection URL (auto-constructed in docker-compose)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment if Redis auth is enabled

# Full connection URL
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# -------------------------------------------
# Logging & Observability
# -------------------------------------------
LOG_LEVEL=debug
# Options: debug, info, warn, error
# Note: debug is only enabled in development

TRACE_ENABLED=true
# Enable trace_id propagation

# -------------------------------------------
# Security & Authentication
# -------------------------------------------
# JWT Secret (use a strong random string in production)
JWT_SECRET=change_this_to_a_secure_random_string_in_production_min_32_chars

# JWT Access Token expiration (examples: 15m, 1h, 1d)
JWT_ACCESS_EXPIRY=15m

# JWT Refresh Token expiration (examples: 7d, 30d)
JWT_REFRESH_EXPIRY=7d

# Bcrypt salt rounds (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=12

# Session secret (for cookie signing if needed)
SESSION_SECRET=another_secure_random_string_here

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
# 100 requests per 60 seconds per IP

# Critical endpoints have stricter limits (configured in code)
# - Login: 5 per minute
# - Register: 3 per minute  
# - Bid: 30 per minute

# -------------------------------------------
# pgAdmin (Development Tools)
# -------------------------------------------
PGADMIN_EMAIL=admin@ironloot.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# -------------------------------------------
# Business Rules (configurable)
# -------------------------------------------
# Soft-close window in seconds
AUCTION_SOFT_CLOSE_WINDOW_SEC=120

# Payment expiration in hours
PAYMENT_EXPIRATION_HOURS=72

# Dispute window in days (after delivery)
DISPUTE_WINDOW_DAYS=14

# -------------------------------------------
# Payment Providers
# -------------------------------------------
# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN="YOUR_MP_ACCESS_TOKEN"
MERCADO_PAGO_WEBHOOK_SECRET="YOUR_MP_WEBHOOK_SECRET"

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BUSINESS_EMAIL=merchant@example.com
PAYPAL_MODE=sandbox

# Base URLs
API_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Phase 2 — Multi-service architecture (PT-015 activated)
# ─────────────────────────────────────────────────────────────

# Feature Flags
BASE_ENABLED=true
CLIENT_ENABLED=true
ADMIN_ENABLED=true

# Service URLs
# Development (Docker / local): use subdomain pattern (add to hosts file)
#   127.0.0.1  base.localhost
#   127.0.0.1  client.localhost
#   127.0.0.1  api.localhost
#   127.0.0.1  admin.localhost
# Production: replace with real HTTPS URLs
BASE_URL=http://base.localhost
CLIENT_URL=http://client.localhost
ADMIN_URL=http://admin.localhost
API_URL=http://api.localhost

# Cookie configuration (cross-subdomain SSO)
# ─── COOKIE_DOMAIN options ────────────────────────────────────────────────────
# Local dev with *.localhost subdomains:
#   Chrome ≥ 90 does NOT share cookies between base.localhost and client.localhost
#   when domain=localhost (without dot). Options:
#
#   Option A — No cross-subdomain SSO (simplest, each subdomain gets its own session):
#     COOKIE_DOMAIN=       (empty — browser scopes cookie to the emitting host)
#
#   Option B — Cross-subdomain SSO with custom .local domain:
#     Add to /etc/hosts:  127.0.0.1 ironloot.local base.ironloot.local client.ironloot.local
#     Set:                COOKIE_DOMAIN=.ironloot.local
#     This reliably shares cookies across all subdomains (works in all browsers).
#
#   Option C — Firefox-only local dev (domain=localhost):
#     COOKIE_DOMAIN=localhost   ← works in Firefox, NOT in Chrome ≥ 90
#
#   Production (HTTPS):
#     COOKIE_DOMAIN=.ironloot.com   (with leading dot — share across all *.ironloot.com)
#
#   → See SSO validation runbook: implementation/SSO_VALIDATION_RUNBOOK.md
COOKIE_DOMAIN=
COOKIE_SAMESITE=Lax
# Set to true only in production (HTTPS required)
COOKIE_SECURE=false

# CORS — comma-separated list of allowed origins
# Include all active subdomains + legacy web/ during transition
ALLOWED_ORIGINS=http://localhost:5173,http://base.localhost,http://client.localhost,http://admin.localhost,http://localhost:3001
