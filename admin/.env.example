# Iron Loot — Admin Panel Environment Variables
# Copy to .env and fill in real values before starting the service.

# ─── Server ─────────────────────────────────────────────────────────────────
ADMIN_PORT=3001
NODE_ENV=development

# ─── API Connection ──────────────────────────────────────────────────────────
# URL of the backend API used by the admin to proxy requests via X-Admin-Key.
API_URL=http://api:3000

# Admin API key — must match the key expected by the API AdminAuthGuard.
ADMIN_API_KEY=change-me-admin-api-key

# ─── Session ─────────────────────────────────────────────────────────────────
# Secret used to sign admin session cookies. Min 32 chars in production.
ADMIN_SESSION_SECRET=change-me-admin-session-secret-min-32-chars

# Session TTL in milliseconds (default: 8 hours = 28800000).
ADMIN_SESSION_TTL_MS=28800000

# ─── Redis (Session Store) ───────────────────────────────────────────────────
# Redis is used to persist admin sessions across process restarts and replicas.
# If Redis is unavailable at startup, the admin falls back to in-memory store
# (NOT suitable for production or horizontal scaling).
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment if Redis auth is required
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}  # Alternative: full URL form

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
